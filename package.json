{
  "name": "ngmaker",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "dev": "ng serve",
    "build": "rm -rf docs; ng build; mv dist/ngmaker/browser/ docs; cp docs/index.html docs/404.html",
    "build:windows": "rmdir /s /q docs & ng build & move dist/ngmaker/browser/ docs & copy docs/index.html docs/404.html",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:ngmaker": "bunx dist/ngmaker/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.3",
    "@angular/common": "^19.2.3",
    "@angular/compiler": "^19.2.3",
    "@angular/core": "^19.2.3",
    "@angular/forms": "^19.2.3",
    "@angular/platform-browser": "^19.2.3",
    "@angular/platform-browser-dynamic": "^19.2.3",
    "@angular/platform-server": "^19.2.3",
    "@angular/router": "^19.2.3",
    "@angular/service-worker": "^19.2.3",
    "@angular/ssr": "^19.2.4",
    "@tailwindcss/postcss": "^4.0.15",
    "express": "^4.21.2",
    "postcss": "^8.5.3",
    "rxjs": "~7.8.2",
    "tailwindcss": "^4.0.15",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.4",
    "@angular/cli": "^19.2.4",
    "@angular/compiler-cli": "^19.2.3",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.7",
    "@types/node": "^22.13.11",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.8.2"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "esbuild",
    "lmdb",
    "msgpackr-extract"
  ]
}